generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "adhoc_analysis", "import_archive"]
}

enum Role {
  ADMIN
  USER

  @@schema("public")
}

enum DataSourceType {
  POSTGRESQL
  MYSQL
  MONGODB
  REST_API
  S3
  BIGQUERY

  @@schema("public")
}

enum SettingCategory {
  SECURITY
  IDENTITIES
  DATA_SOURCES

  @@schema("public")
}

enum PluginScope {
  PERSONAL
  SHARED

  @@schema("public")
}

enum PluginRuntime {
  BROWSER
  SERVER
  BOTH

  @@schema("public")
}

enum AuditAction {
  LOGIN
  LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  DATASOURCE_CREATED
  DATASOURCE_UPDATED
  DATASOURCE_DELETED
  QUERY_EXECUTED
  SETTINGS_UPDATED

  @@schema("public")
}

enum TemporaryDatasetFormat {
  CSV
  XLS
  XLSX

  @@schema("adhoc_analysis")
}

enum PersistentDatasetOrigin {
  IMPORT
  WEB_SCRAPE

  @@schema("import_archive")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  headline           String?
  location           String?
  summary            String?
  experience         String?
  education          String?
  skills             String?
  websiteUrl         String?
  linkedinUrl        String?
  mobileNumber       String?             @unique
  passwordHash       String
  role               Role                @default(USER)
  isActive           Boolean             @default(true)
  sessionVersion     Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  defaultAiProvider  String?             @default("copilot")
  auditLogs          AuditLog[]          @relation("AuditActor")
  dataSources        DataSource[]        @relation("DataSourceOwner")
  dataSourceAccesses DataSourceAccess[]
  loginOtpChallenges LoginOtpChallenge[]
  notes              Note[]              @relation("UserNotes")
  appSettings        AppSetting[]        @relation("AppSettingActor")
  pluginDefinitions  PluginDefinition[]  @relation("PluginOwner")
  aiProviderSettings UserAiProviderSetting[] @relation("UserAiProviderSettings")
  temporaryAnalysisDatasets TemporaryAnalysisDataset[] @relation("TemporaryAnalysisOwner")
  persistentDatasets PersistentDataset[] @relation("PersistentDatasetOwner")
  transformWorkflows TransformWorkflow[] @relation("TransformWorkflowOwner")

  @@schema("public")
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotes", fields: [userId], references: [id], onDelete: Cascade)
  content   String   @default("")
  color     String   @default("yellow")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@schema("public")
}

model DataSource {
  id               String         @id @default(cuid())
  name             String
  description      String?
  dataDictionary   String?
  type             DataSourceType
  configCiphertext String
  createdById      String?
  createdBy        User?          @relation("DataSourceOwner", fields: [createdById], references: [id], onDelete: SetNull)
  accessList       DataSourceAccess[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@schema("public")
}

model DataSourceAccess {
  dataSourceId String
  userId       String
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([dataSourceId, userId])
  @@index([userId])
  @@schema("public")
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  actorId    String?
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, createdAt])
  @@schema("public")
}

model AppSetting {
  key         String          @id
  category    SettingCategory
  value       String
  isSecret    Boolean         @default(false)
  updatedById String?
  updatedBy   User?           @relation("AppSettingActor", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@schema("public")
}

model UserAiProviderSetting {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserAiProviderSettings", fields: [userId], references: [id], onDelete: Cascade)
  provider        String
  endpoint        String   @default("")
  model           String   @default("")
  apiKeyCiphertext String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@schema("public")
}

model PluginDefinition {
  id              String        @id @default(cuid())
  name            String
  description     String?
  sourceCode      String
  protocolVersion String
  generationPrompt String?
  provider        String?
  providerModel   String?
  scope           PluginScope   @default(PERSONAL)
  runtime         PluginRuntime @default(BOTH)
  ownerId         String?
  owner           User?         @relation("PluginOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([scope, ownerId, updatedAt])
  @@schema("public")
}

model LoginOtpChallenge {
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash    String
  destination String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@schema("public")
}

model TemporaryAnalysisDataset {
  id               String                   @id @default(cuid())
  label            String
  tableName        String                   @unique
  sourceFileName   String
  sourceFileFormat TemporaryDatasetFormat
  sourceSheetName  String?
  rowCount         Int
  columnCount      Int
  columns          Json
  metadata         Json?
  uploadedById     String
  uploadedBy       User                     @relation("TemporaryAnalysisOwner", fields: [uploadedById], references: [id], onDelete: Cascade)
  expiresAt        DateTime
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  rows             TemporaryAnalysisDatasetRow[]

  @@index([uploadedById, expiresAt])
  @@schema("adhoc_analysis")
}

model TemporaryAnalysisDatasetRow {
  id        String                   @id @default(cuid())
  datasetId String
  dataset   TemporaryAnalysisDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  rowIndex  Int
  payload   Json
  createdAt DateTime                 @default(now())

  @@unique([datasetId, rowIndex])
  @@index([datasetId])
  @@schema("adhoc_analysis")
}

model PersistentDataset {
  id             String                  @id @default(cuid())
  label          String
  tableName      String                  @unique
  dataDictionary String?
  origin         PersistentDatasetOrigin
  sourceLabel    String?
  sourceUri      String?
  rowCount       Int
  columnCount    Int
  columns        Json
  metadata       Json?
  createdById    String?
  createdBy      User?                   @relation("PersistentDatasetOwner", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  rows           PersistentDatasetRow[]

  @@index([origin, createdAt])
  @@index([createdById, createdAt])
  @@schema("import_archive")
}

model PersistentDatasetRow {
  id        String            @id @default(cuid())
  datasetId String
  dataset   PersistentDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  rowIndex  Int
  payload   Json
  createdAt DateTime          @default(now())

  @@unique([datasetId, rowIndex])
  @@index([datasetId])
  @@schema("import_archive")
}

model TransformWorkflow {
  id        String   @id @default(cuid())
  name      String
  definition Json
  ownerId   String
  owner     User     @relation("TransformWorkflowOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, name])
  @@index([ownerId, updatedAt])
  @@schema("public")
}
